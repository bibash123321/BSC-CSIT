<?xml version="1.0"?>

<xsl:stylesheet 
version="1.0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform">


<xsl:template match="/">

<html>

<body>

<h2>Student Name and Project Name (Hari Bashyal)</h2>

<table border="1">

<tr>
<th>Name</th>
<th>Project Name</th>
</tr>


<xsl:for-each select="students/student">

<tr>

<td>
<xsl:value-of select="name"/>
</td>


<td>
<xsl:value-of select="project"/>
</td>


</tr>

</xsl:for-each>


</table>


</body>

</html>


</xsl:template>


</xsl:stylesheet>